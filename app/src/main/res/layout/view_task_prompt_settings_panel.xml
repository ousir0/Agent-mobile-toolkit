<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/task_prompt_model_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="@string/task_prompt_model_label"
        app:boxBackgroundColor="@color/task_prompt_input_surface"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusTopStart="14dp"
        app:boxStrokeColor="@color/task_prompt_stroke"
        app:endIconDrawable="@drawable/chevron_right"
        app:endIconMode="custom"
        app:endIconTint="@color/task_prompt_text_secondary"
        app:hintTextColor="@color/task_prompt_text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/task_prompt_model_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:cursorVisible="false"
            android:focusable="false"
            android:inputType="none"
            android:textColor="@color/task_prompt_text_primary"
            android:textColorHint="@color/task_prompt_text_secondary" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/task_prompt_reasoning_tile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/task_prompt_input_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/task_prompt_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:breakStrategy="simple"
                        android:ellipsize="end"
                        android:hyphenationFrequency="none"
                        android:maxLines="1"
                        android:text="@string/task_prompt_reasoning"
                        android:textColor="@color/task_prompt_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:breakStrategy="simple"
                        android:ellipsize="end"
                        android:hyphenationFrequency="none"
                        android:maxLines="2"
                        android:text="@string/task_prompt_reasoning_description"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/task_prompt_reasoning_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:text=""
                        android:textColor="@color/task_prompt_text_primary" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/task_prompt_vision_tile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/task_prompt_input_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/task_prompt_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:breakStrategy="simple"
                        android:ellipsize="end"
                        android:hyphenationFrequency="none"
                        android:maxLines="1"
                        android:text="@string/task_prompt_vision"
                        android:textColor="@color/task_prompt_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:breakStrategy="simple"
                        android:ellipsize="end"
                        android:hyphenationFrequency="none"
                        android:maxLines="2"
                        android:text="@string/task_prompt_vision_description"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/task_prompt_vision_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:text=""
                        android:textColor="@color/task_prompt_text_primary" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/task_prompt_advanced_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="40dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/task_prompt_advanced"
            android:textColor="@color/task_prompt_text_secondary"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/task_prompt_advanced_chevron"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/chevron_right"
            app:tint="@color/task_prompt_text_secondary" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/task_prompt_advanced_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/task_prompt_max_steps_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/task_prompt_max_steps"
            app:boxBackgroundColor="@color/task_prompt_input_surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/task_prompt_stroke"
            app:hintTextColor="@color/task_prompt_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/task_prompt_max_steps_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:textColor="@color/task_prompt_text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/task_prompt_timeout_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/task_prompt_timeout"
            app:boxBackgroundColor="@color/task_prompt_input_surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/task_prompt_stroke"
            app:hintTextColor="@color/task_prompt_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/task_prompt_timeout_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:textColor="@color/task_prompt_text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/task_prompt_temperature_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/task_prompt_temperature"
            app:boxBackgroundColor="@color/task_prompt_input_surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/task_prompt_stroke"
            app:hintTextColor="@color/task_prompt_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/task_prompt_temperature_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:inputType="numberDecimal"
                android:textColor="@color/task_prompt_text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</LinearLayout>
